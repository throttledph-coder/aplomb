// @see - https://www.electron.build/configuration/configuration
{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.aplomb.app",
  "asar": true,
  "productName": "Aplomb",
  "directories": {
    "output": "release/${version}"
  },
  // GitHub Releases provider so electron-builder emits latest.yml + .blockmap
  // (the metadata electron-updater reads to detect + download new versions).
  "publish": [
    {
      "provider": "github",
      "owner": "throttledph-coder",
      "repo": "aplomb"
    }
  ],
  "files": [
    "dist",
    "dist-electron"
  ],
  // better-sqlite3 ships a native .node binary that cannot load from inside an
  // asar archive — keep it unpacked so require() resolves it at runtime.
  "asarUnpack": [
    "**/node_modules/better-sqlite3/**"
  ],
  "mac": {
    // dmg for first install; zip is required for electron-updater on macOS
    // (latest-mac.yml references the zip). Unsigned for now — see build-mac.yml.
    "target": [
      "dmg",
      "zip"
    ],
    "artifactName": "${productName}-Mac-${version}-${arch}.${ext}"
  },
  "win": {
    "icon": "build/icon.png",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "${productName}-Windows-${version}-Setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },
  "linux": {
    "target": [
      "AppImage"
    ],
    "artifactName": "${productName}-Linux-${version}.${ext}"
  }
}
